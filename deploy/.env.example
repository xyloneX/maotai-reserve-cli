# 复制为 deploy/.env 或写入 /opt/maotai/.env 后 source

# 管理后台登录（必改）
# 最高管理员（你）— 含系统设置、代理池
MT_OWNER_USERNAME=owner
MT_OWNER_PASSWORD=请改成强密码

# 甲方日常操作员 — 无系统设置权限
MT_CLIENT_USERNAME=client
MT_CLIENT_PASSWORD=请改成甲方专用密码

# 兼容旧配置（可选，与 owner 二选一）
MT_ADMIN_USERNAME=admin
MT_ADMIN_PASSWORD=请改成强密码

# JWT 与凭证加密（必改，32 位以上随机）
MT_SECRET_KEY=请改成随机长字符串

# 允许访问 API 的前端域名（多个用逗号分隔）
MT_CORS_ORIGINS=https://你的域名.com

# 数据库（默认 SQLite，生产几百～1000 号建议 MySQL）
# MT_DATABASE_URL=sqlite:////opt/maotai/data/admin.db
# MT_DATABASE_URL=mysql+pymysql://maotai:密码@127.0.0.1:3306/maotai?charset=utf8mb4
# 迁移: MYSQL_URL='...' python scripts/migrate_sqlite_to_mysql.py

# 项目根目录（systemd 用）
MT_APP_ROOT=/opt/maotai

# ---------- Android 应用内更新 ----------
# 发布新 APK 后：versionCode 必须大于旧版，并上传文件到 /opt/maotai/downloads/maotai-reserve.apk
MT_APP_LATEST_VERSION_CODE=1
MT_APP_LATEST_VERSION_NAME=1.0.0
MT_APP_DOWNLOAD_URL=http://你的服务器IP/downloads/maotai-reserve.apk
MT_APP_RELEASE_NOTES=
MT_APP_FORCE_UPDATE=false

# ---------- 服务器定时任务 ----------
MT_SCHEDULER_ENABLED=true
MT_SCHEDULER_TIMEZONE=Asia/Shanghai
MT_LOTTERY_CHECK_TIME=18:03:00
MT_TOKEN_CHECK_TIME=07:00:00
MT_WEEKEND_RESERVE_ENABLED=true
MT_WEEKEND_RESERVE_TIME=15:05:00
